# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
.venv/
__pycache__/

# data and results
/primary_data/
/secondary_data/
/visualizations/
# /intermediate_results/ # Keep results for showcase if needed, but usually ignore
/intermediate_results/*.json

# diagnostic scripts (root)
/*.js
/*.mjs
!eslint.config.mjs
!next.config.ts

# reports
# /interim_reports/ # Keep reports if needed, but usually ignore
